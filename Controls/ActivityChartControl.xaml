<UserControl x:Class="AutodeskIDMonitor.Controls.ActivityChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="280" d:DesignWidth="800">
    
    <UserControl.Resources>
        <!-- Activity Colors -->
        <SolidColorBrush x:Key="RevitColor" Color="#00B4D8"/>
        <SolidColorBrush x:Key="MeetingColor" Color="#9C27B0"/>
        <SolidColorBrush x:Key="IdleColor" Color="#ADB5BD"/>
        <SolidColorBrush x:Key="OtherColor" Color="#FF9800"/>
        <SolidColorBrush x:Key="OvertimeColor" Color="#E65100"/>
        <SolidColorBrush x:Key="WorkHourBg" Color="#E8F5E9"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Chart Area -->
        <Border Grid.Row="0" Background="White" Padding="5,10,15,5">
            <Grid x:Name="ChartGrid" Margin="35,0,5,25">
                <!-- Y-Axis Labels and Hour bars added programmatically -->
            </Grid>
        </Border>
        
        <!-- Summary Stats -->
        <Border Grid.Row="1" Padding="15,10" Background="#F5F5F5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Stats Row -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                        <TextBlock x:Name="TotalHoursText" Text="0.0h" FontSize="22" FontWeight="Bold" Foreground="#00B4D8" VerticalAlignment="Center"/>
                        <TextBlock Text=" Total Work" Foreground="#666" VerticalAlignment="Center" FontSize="12" Margin="5,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                        <Border Background="#00B4D8" Width="12" Height="12" CornerRadius="2" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RevitHoursText" Text="0.0h" FontSize="18" FontWeight="Bold" Foreground="#00B4D8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock Text=" Revit" Foreground="#666" VerticalAlignment="Center" FontSize="11" Margin="3,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                        <Border Background="#9C27B0" Width="12" Height="12" CornerRadius="2" VerticalAlignment="Center"/>
                        <TextBlock x:Name="MeetingHoursText" Text="0.0h" FontSize="18" FontWeight="Bold" Foreground="#9C27B0" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock Text=" Meetings" Foreground="#666" VerticalAlignment="Center" FontSize="11" Margin="3,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                        <Border Background="#ADB5BD" Width="12" Height="12" CornerRadius="2" VerticalAlignment="Center"/>
                        <TextBlock x:Name="IdleHoursText" Text="0.0h" FontSize="18" FontWeight="Bold" Foreground="#ADB5BD" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock Text=" Idle" Foreground="#666" VerticalAlignment="Center" FontSize="11" Margin="3,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#E65100" Width="12" Height="12" CornerRadius="2" VerticalAlignment="Center"/>
                        <TextBlock x:Name="OvertimeHoursText" Text="0.0h" FontSize="18" FontWeight="Bold" Foreground="#E65100" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock Text=" Overtime" Foreground="#666" VerticalAlignment="Center" FontSize="11" Margin="3,0,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Legend -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#E8F5E9" Width="14" Height="14" BorderBrush="#A5D6A7" BorderThickness="1" Margin="0,0,5,0"/>
                    <TextBlock Text="Work Hours (8AM-6PM)" FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
