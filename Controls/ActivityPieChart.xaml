<UserControl x:Class="AutodeskIDMonitor.Controls.ActivityPieChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="200">
    
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Pie Chart Canvas -->
        <Viewbox Grid.Row="0" Stretch="Uniform">
            <Canvas x:Name="PieCanvas" Width="140" Height="140"/>
        </Viewbox>
        
        <!-- Legend -->
        <StackPanel Grid.Row="1" x:Name="LegendPanel" Orientation="Vertical" Margin="5,10,5,0">
            <!-- Legend items will be added programmatically -->
        </StackPanel>
    </Grid>
</UserControl>
