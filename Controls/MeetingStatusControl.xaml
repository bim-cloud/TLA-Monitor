<UserControl x:Class="AutodeskIDMonitor.Controls.MeetingStatusControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="350">
    
    <Border x:Name="MainBorder" CornerRadius="10" Padding="12" Background="#F8F9FA"
            BorderThickness="1" BorderBrush="#E9ECEF">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Animated Icon with Pulse Ring -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <!-- Pulse Ring (only visible during meetings) -->
                <Ellipse x:Name="PulseRing" Width="44" Height="44" 
                         Fill="Transparent" Stroke="#9C27B0" StrokeThickness="2"
                         Opacity="0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- Icon Circle -->
                <Border x:Name="IconBorder" Width="44" Height="44" CornerRadius="22" 
                        Background="#E9ECEF">
                    <TextBlock x:Name="IconText" Text="📞" FontSize="20" 
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
            
            <!-- Status Text -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="No active meetings" 
                           FontWeight="SemiBold" FontSize="14" Foreground="#495057"/>
                <TextBlock x:Name="AppNameText" Text="" FontSize="12" Foreground="#6C757D" Margin="0,2,0,0"/>
            </StackPanel>
            
            <!-- Duration with Modern Display -->
            <Border Grid.Column="2" x:Name="DurationBorder" CornerRadius="8" Padding="12,6" 
                    Background="Transparent" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Right">
                    <TextBlock x:Name="DurationText" Text="" FontFamily="Consolas" FontSize="18" FontWeight="Bold" 
                              Foreground="#6C757D" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="DurationLabel" Text="" FontSize="10" Foreground="#ADB5BD" HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
