<Window x:Class="AutodeskIDMonitor.Views.AdminLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Login" 
        Height="280" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="🔐" FontSize="40" VerticalAlignment="Center"/>
            <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Admin Authentication" FontSize="18" FontWeight="Bold" Foreground="#2596BE"/>
                <TextBlock Text="Enter admin password to unlock" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Password Input -->
        <TextBlock Grid.Row="1" Text="Password:" Margin="0,20,0,5"/>
        <PasswordBox Grid.Row="2" x:Name="PasswordBox" Height="35" FontSize="14" 
                     KeyDown="PasswordBox_KeyDown"/>
        
        <!-- Error Message -->
        <TextBlock Grid.Row="3" x:Name="ErrorText" 
                   Foreground="Red" FontSize="12" Margin="0,10,0,0"
                   Visibility="Collapsed"/>
        
        <!-- Attempt Counter -->
        <TextBlock Grid.Row="4" x:Name="AttemptText" 
                   Foreground="Gray" FontSize="11" Margin="0,5,0,0"
                   Visibility="Collapsed"/>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Height="35" Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#E0E0E0" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="🔓 Login" Width="100" Height="35"
                    Click="Login_Click"
                    Background="#2596BE" Foreground="White" BorderThickness="0" Cursor="Hand"
                    FontWeight="Bold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
