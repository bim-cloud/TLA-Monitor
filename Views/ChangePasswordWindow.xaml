<Window x:Class="AutodeskIDMonitor.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Admin Password" 
        Height="405" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🔑 Change Admin Password" 
                   FontSize="18" FontWeight="Bold" Foreground="#2596BE" Margin="0,0,0,25"/>
        
        <!-- Current Password -->
        <TextBlock Grid.Row="1" Text="Current Password:" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="2" x:Name="CurrentPasswordBox" Height="32" FontSize="14" Margin="0,0,0,15"/>
        
        <!-- New Password -->
        <TextBlock Grid.Row="3" Text="New Password:" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="4" x:Name="NewPasswordBox" Height="32" FontSize="14" Margin="0,0,0,15"/>
        
        <!-- Confirm Password -->
        <TextBlock Grid.Row="5" Text="Confirm New Password:" Margin="0,0,0,5"/>
        <PasswordBox Grid.Row="6" x:Name="ConfirmPasswordBox" Height="32" FontSize="14" Margin="0,0,0,10"/>
        
        <!-- Error Message -->
        <TextBlock Grid.Row="7" x:Name="ErrorText" 
                   Foreground="Red" FontSize="12" Margin="0,5,0,0"
                   Visibility="Collapsed" TextWrapping="Wrap"/>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Height="35" Margin="0,0,10,0"
                    Click="Cancel_Click"
                    Background="#E0E0E0" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="💾 Save" Width="100" Height="35"
                    Click="Save_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand"
                    FontWeight="Bold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
