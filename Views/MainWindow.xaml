<Window x:Class="AutodeskIDMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AutodeskIDMonitor.ViewModels"
        xmlns:conv="clr-namespace:AutodeskIDMonitor.Converters"
        xmlns:controls="clr-namespace:AutodeskIDMonitor.Controls"
        Title="Autodesk ID Monitor - Tangent Landscape Architecture" 
        Height="905" Width="1258" MinHeight="600" MinWidth="950"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6FB">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:BoolToStringConverter x:Key="BoolToString"/>
        <conv:BoolToColorConverter x:Key="BoolToColor"/>
        <conv:StatusToBackgroundConverter x:Key="StatusToBackground"/>
        <conv:EventTypeToBackgroundConverter x:Key="EventTypeToBackground"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:IdStatusToColorConverter x:Key="IdStatusToColor"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <conv:RowNumberConverter x:Key="RowNumberConverter"/>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.06" Color="#000"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#CBD5E1"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECONDARY BUTTON -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D8DCE6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                                <Setter TargetName="bd" Property="Background" Value="#EBF0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#E11D48"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E11D48"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TABCONTROL -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBd" Background="White" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#2563EB"/>
                                <Setter TargetName="TabBd" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#334155"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATAGRID -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8EBF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F3F9"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EEF1F8"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#D8DCE6"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#D8DCE6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F7F8FC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="bd" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CARD -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E8EBF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.04" Color="#000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TABLE CARD (no padding) -->
        <Style x:Key="TableCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E8EBF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.04" Color="#000"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.3">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#0F2744" Offset="0.4"/>
                    <GradientStop Color="#162D50" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.12" Color="#000"/>
            </Border.Effect>
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Resources/Tangent_logo.png" Height="34" Margin="0,0,10,0"/>
                    <TextBlock Text="Tangent ID Monitor" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#1A3B5C" CornerRadius="5" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center" BorderBrush="#2A5580" BorderThickness="1">
                        <TextBlock Text="v2.0" FontSize="10" FontWeight="SemiBold" Foreground="#5EAFD6"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#1A3050" CornerRadius="12" Padding="8,3,10,3" Margin="0,0,10,0" BorderBrush="#1F3A5A" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding IsConnected, Converter={StaticResource BoolToColor}, ConverterParameter=#34D399|#F87185}"/>
                            <TextBlock Text="{Binding ConnectionStatusText}" FontSize="11" Foreground="#8EAEC8" FontWeight="Medium"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding CloudStatusText}" FontSize="11" Foreground="#5A7A96" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🌐" Command="{Binding OpenWebDashboardCommand}" Width="32" Height="32" FontSize="14" ToolTip="Web Dashboard" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="#1A3050" CornerRadius="6" BorderBrush="#1F3A5A" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#254060"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="⬆️ Update" Command="{Binding OpenDownloadPageCommand}"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibility}}"
                            Height="30" FontSize="11" FontWeight="SemiBold" Foreground="White" Padding="10,4" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#D97706" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="{Binding AdminStatusText}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToColor}, ConverterParameter=#6EE7B7|#5A7A96}"/>
                    <Button Content="{Binding AdminButtonText}" Command="{Binding ToggleAdminCommand}" Width="34" Height="34" FontSize="16" ToolTip="Admin Login/Logout">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToColor}, ConverterParameter=#15803D|#1A3050}"
                                        CornerRadius="6" BorderBrush="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToColor}, ConverterParameter=#22C55E|#1F3A5A}" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ TABS ═══════════ -->
        <TabControl Grid.Row="1" Margin="10,0,10,10" SelectedIndex="{Binding SelectedTabIndex}">

            <!-- TAB 1: USER PROFILES -->
            <TabItem Header="👥 Profiles">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="🔄 Refresh" Command="{Binding RefreshProfilesCommand}" Style="{StaticResource PrimaryButton}" Width="95" Margin="0,0,8,0"/>
                        <Button Content="📊 Export" Command="{Binding ExportToExcelCommand}" Style="{StaticResource SecondaryButton}" Width="90"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" Grid.Column="0" ItemsSource="{Binding UserProfiles}" SelectedItem="{Binding SelectedProfile}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" Margin="0,0,10,0" SelectionMode="Single">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Background" Value="#F0FDF4"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="AUTODESK EMAIL" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="STATUS" Binding="{Binding StatusText}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True"><Setter Property="Foreground" Value="#059669"/></DataTrigger>
                                            <DataTrigger Binding="{Binding IsActive}" Value="False"><Setter Property="Foreground" Value="#E11D48"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="🔒 Admin access required" FontStyle="Italic" Foreground="#94A3B8" Margin="0,0,0,12" FontSize="11"
                                       Visibility="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                            <TextBlock Text="Edit Profile" FontSize="14" FontWeight="Bold" Foreground="#2563EB" Margin="0,0,0,16"/>
                            <TextBlock Text="DISPLAY NAME" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="#64748B" FontSize="10"/>
                            <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsAdminLoggedIn}" Margin="0,0,0,12"/>
                            <TextBlock Text="AUTODESK EMAIL" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="#64748B" FontSize="10"/>
                            <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsAdminLoggedIn}" Margin="0,0,0,12"/>
                            <TextBlock Text="PASSWORD" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="#64748B" FontSize="10"/>
                            <TextBox Text="{Binding EditPassword, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsAdminLoggedIn}" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="💾 Save" Command="{Binding SaveProfileCommand}" Style="{StaticResource PrimaryButton}" Width="75" Margin="0,0,6,0" IsEnabled="{Binding IsAdminLoggedIn}"/>
                                <Button Content="➕ Add" Command="{Binding NewProfileCommand}" Style="{StaticResource SecondaryButton}" Width="75" Margin="0,0,6,0" IsEnabled="{Binding IsAdminLoggedIn}"/>
                                <Button Content="🗑️ Delete" Command="{Binding DeleteProfileCommand}" Style="{StaticResource DangerButton}" Width="80" IsEnabled="{Binding IsAdminLoggedIn}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB 2: CURRENT STATUS -->
            <TabItem Header="📊 Status">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="🔄 Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Width="95" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding LastRefreshText}" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentSessions}" SelectedItem="{Binding SelectedSession}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" ColumnHeaderHeight="36" MinRowHeight="34">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Background" Value="#EBF0FF"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasSharedId}" Value="True">
                                        <Setter Property="Background" Value="#FFFBEB"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="SL" Width="36" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource RowNumberConverter}}"
                                                   HorizontalAlignment="Center" FontWeight="Medium" Foreground="#94A3B8"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="PERSON NAME" Binding="{Binding PersonName}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#0F172A"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="AUTODESK EMAIL" Binding="{Binding AutodeskEmail}" Width="220">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Foreground" Value="#64748B"/><Setter Property="ToolTip" Value="{Binding AutodeskEmail}"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="WINDOWS USER" Binding="{Binding WindowsUser}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#64748B"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="MACHINE ID" Binding="{Binding MachineId}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="FontFamily" Value="Consolas"/><Setter Property="FontSize" Value="10.5"/><Setter Property="Foreground" Value="#94A3B8"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="STATUS" Width="65">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsLoggedIn, Converter={StaticResource BoolToString}, ConverterParameter=✅ In|❌ Out}"
                                                   Foreground="{Binding IsLoggedIn, Converter={StaticResource BoolToColor}, ConverterParameter=#059669|#E11D48}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="ID STATUS" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IdStatus}" Foreground="{Binding IdStatus, Converter={StaticResource IdStatusToColor}}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="SHARED ID" Binding="{Binding SharedIdInfo}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#D97706"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="10" Margin="0,10,0,0"
                            Visibility="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Edit User:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#64748B" FontSize="11"/>
                            <TextBox Text="{Binding EditSessionName, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,8,0"/>
                            <Button Content="💾 Save" Command="{Binding SaveSessionNameCommand}" Style="{StaticResource PrimaryButton}" Width="80" Margin="0,0,6,0"/>
                            <Button Content="↩️ Reset" Command="{Binding ResetSessionNameCommand}" Style="{StaticResource SecondaryButton}" Width="75"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB 3: ACTIVITY HISTORY -->
            <TabItem Header="📋 History">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="44"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Activity Log" FontSize="13" FontWeight="SemiBold" Foreground="#2563EB" VerticalAlignment="Center"/>
                        <Button Content="🔄 Refresh" Command="{Binding RefreshHistoryCommand}" Style="{StaticResource PrimaryButton}" Width="95" Margin="16,0,0,0"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ActivityHistory}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding EventType, Converter={StaticResource EventTypeToBackground}}"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TIMESTAMP" Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="155"/>
                            <DataGridTextColumn Header="EVENT" Binding="{Binding EventType}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="PERSON" Binding="{Binding PersonName}" Width="140"/>
                            <DataGridTextColumn Header="AUTODESK EMAIL" Binding="{Binding AutodeskEmail}" Width="210"/>
                            <DataGridTextColumn Header="PREVIOUS EMAIL" Binding="{Binding PreviousEmail}" Width="190"/>
                            <DataGridTextColumn Header="MACHINE" Binding="{Binding MachineId}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="📥 Export" Command="{Binding ExportHistoryCommand}" Style="{StaticResource PrimaryButton}" Width="95" Margin="0,0,6,0"/>
                        <Button Content="🗑️ Clear" Command="{Binding ClearHistoryCommand}" Style="{StaticResource DangerButton}" Width="85"
                                Visibility="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 4: PROJECTS (COLLAPSED) -->
            <TabItem Header="📁 Projects" Visibility="Collapsed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="🔄 Refresh" Command="{Binding RefreshProjectsCommand}" Style="{StaticResource PrimaryButton}" Width="95" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ActiveUserCount}" FontWeight="SemiBold" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="active users" Foreground="#94A3B8" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Projects}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PROJECT" Binding="{Binding ProjectName}" Width="*"/>
                            <DataGridTextColumn Header="USERS" Binding="{Binding UserCount}" Width="60"/>
                            <DataGridTextColumn Header="TOTAL HOURS" Binding="{Binding TotalHours, StringFormat=F1}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- TAB 5: TIME TRACKING (Admin) -->
            <TabItem Header="⏱️ Time Tracking" Visibility="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToVisibility}}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="260"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="📅" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker SelectedDate="{Binding SelectedDate}" Width="140" Margin="0,0,8,0"/>
                        <Button Content="🔄 Refresh" Command="{Binding RefreshTimeTrackingCommand}" Style="{StaticResource PrimaryButton}" Width="95" Margin="0,0,6,0"/>
                        <Button Content="📁 Project Time" Command="{Binding ViewProjectTimeCommand}" Style="{StaticResource SecondaryButton}" Width="105" Margin="0,0,6,0"/>
                        <Button Content="📥 Export" Command="{Binding ExportToExcelCommand}" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,6,0"/>
                        <Button Content="📊 Range" Command="{Binding ExportDateRangeCommand}" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,6,0"/>
                        <Button Content="📋 Report" Command="{Binding ExportProjectReportCommand}" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,6,0"/>
                        <Button Content="🗑️ Delete" Command="{Binding DeleteHistoricalDataCommand}" Style="{StaticResource DangerButton}" Width="75" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding WorkDayStatus}" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="11" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Session + Meeting -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <!-- My Session -->
                        <Border Grid.Column="0" Background="White" CornerRadius="10" BorderBrush="#059669" BorderThickness="1,1,1,1"
                                Padding="12,8" Margin="0,0,8,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.04" Color="#000"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁 Project:" Foreground="#64748B" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,5,0"/>
                                <Border Background="#EBF0FF" CornerRadius="5" Padding="8,2" Margin="0,0,12,0" BorderBrush="#DBEAFE" BorderThickness="1">
                                    <TextBlock Text="{Binding LocalCurrentProject}" FontWeight="SemiBold" Foreground="#2563EB" FontSize="12"/>
                                </Border>
                                <TextBlock Text="Active:" Foreground="#64748B" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding LocalSessionDuration}" FontWeight="Bold" FontFamily="Consolas" Foreground="#059669" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Inst:" Foreground="#64748B" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding LocalRevitCount}" FontWeight="Bold" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Idle:" Foreground="#64748B" VerticalAlignment="Center" FontSize="11.5" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding IdleTimeDisplay}" FontWeight="Bold" Foreground="#D97706" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <controls:MeetingStatusControl x:Name="MeetingStatus" Grid.Column="1"/>
                    </Grid>

                    <!-- Revit Processes -->
                    <Border Grid.Row="2" Background="White" CornerRadius="10" BorderBrush="#D1FAE5" BorderThickness="1" Padding="8,5" Margin="0,0,0,8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding LocalRevitProcesses}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="5" Padding="8,3" Margin="0,2,6,2" Background="#EBF0FF" BorderBrush="#DBEAFE" BorderThickness="1" ToolTip="{Binding ProjectName}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄 " FontSize="10"/>
                                                <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" Foreground="#2563EB" MaxWidth="180" TextTrimming="CharacterEllipsis" FontSize="11"/>
                                                <TextBlock Text=" · " Foreground="#94A3B8" FontSize="11"/>
                                                <TextBlock Text="{Binding DurationText}" FontFamily="Consolas" Foreground="#0F172A" FontWeight="Bold" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Hourly Chart -->
                    <Border Grid.Row="3" Background="White" CornerRadius="12" BorderBrush="#E8EBF2" BorderThickness="1" Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.04" Color="#000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#EEF1F8" CornerRadius="12,12,0,0" Padding="14,8">
                                <TextBlock Text="📊 Hourly Activity Breakdown" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                            </Border>
                            <controls:ActivityChartControl x:Name="ActivityChart" Grid.Row="1"/>
                        </Grid>
                    </Border>

                    <!-- All Users + Project Summary + Pie -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="190"/>
                        </Grid.ColumnDefinitions>

                        <!-- Team Activity Table -->
                        <Border Grid.Column="0" Style="{StaticResource TableCard}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#EEF1F8" CornerRadius="12,12,0,0" Padding="12,8">
                                    <TextBlock Text="👥 Team Activity" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                                </Border>
                                <DataGrid Grid.Row="1" x:Name="UsersActivityGrid"
                                          ItemsSource="{Binding AllUsersActivity}" SelectedItem="{Binding SelectedUserActivity, Mode=TwoWay}"
                                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                          RowHeight="30" ColumnHeaderHeight="32" SelectionMode="Single" BorderThickness="0">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentUser}" Value="True">
                                                    <Setter Property="Background" Value="#EBF0FF"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsInMeeting}" Value="True">
                                                    <Setter Property="Background" Value="#F5F3FF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActivityState}" Value="Idle">
                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F8FAFF"/>
                                                </Trigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsCurrentUser}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Sts" Binding="{Binding StatusIcon}" Width="30">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="FontSize" Value="13"/><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="User" Binding="{Binding WindowsDisplayName}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#0F172A"/><Setter Property="FontWeight" Value="Medium"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Revit" Binding="{Binding RevitHours, StringFormat=F1}" Width="44">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#2563EB"/><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Meet" Binding="{Binding MeetingHours, StringFormat=F1}" Width="44">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#7C3AED"/><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Idle" Binding="{Binding IdleHours, StringFormat=F1}" Width="36">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#94A3B8"/><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Total" Binding="{Binding TotalHours, StringFormat=F1}" Width="40">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="OT" Binding="{Binding OvertimeHours, StringFormat=F1}" Width="30">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#D97706"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="App" Binding="{Binding MeetingStatus}" Width="65">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#7C3AED"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Project" Binding="{Binding CurrentProject}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Foreground" Value="#64748B"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Project Summary -->
                        <Border Grid.Column="1" Style="{StaticResource TableCard}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#EEF1F8" CornerRadius="12,12,0,0" Padding="12,8">
                                    <TextBlock Text="📁 Project Hours" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                                </Border>
                                <DataGrid Grid.Row="1" x:Name="ProjectSummaryGrid" ItemsSource="{Binding ProjectSummaries}"
                                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                          MinRowHeight="34" ColumnHeaderHeight="30" SelectionMode="Single" BorderThickness="0"
                                          MouseDoubleClick="ProjectSummaryGrid_MouseDoubleClick">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F8FAFF"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#EBF0FF"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="130">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#2563EB"/><Setter Property="ToolTip" Value="{Binding ProjectName}"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Hrs" Binding="{Binding TotalHours, StringFormat=F1}" Width="44">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#2563EB"/><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Who" Binding="{Binding UsersWorking}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Foreground" Value="#94A3B8"/><Setter Property="FontSize" Value="11"/><Setter Property="ToolTip" Value="{Binding UsersWorking}"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Pie Chart -->
                        <Border Grid.Column="2" Style="{StaticResource TableCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#EEF1F8" CornerRadius="12,12,0,0" Padding="12,8">
                                    <TextBlock Text="📊 Today" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                                </Border>
                                <controls:ActivityPieChart x:Name="ActivityPie" Grid.Row="1" Margin="5"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Bottom Export Buttons -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="🗑️ Reset Today" Command="{Binding ResetTodayTimeDataCommand}" Style="{StaticResource DangerButton}" Width="115" Margin="0,0,16,0"
                                ToolTip="Clear all time tracking data for today"/>
                        <Button Content="📥 Daily Report" Command="{Binding ExportDailyReportCommand}" Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,6,0"/>
                        <Button Content="📁 Project Report" Command="{Binding ExportProjectReportCommand}" Style="{StaticResource PrimaryButton}" Width="125" Margin="0,0,6,0"/>
                        <Button Content="📊 Weekly Report" Command="{Binding ExportDateRangeReportCommand}" Style="{StaticResource PrimaryButton}" Width="125"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 6: PROJECT DASHBOARD (Admin) -->
            <TabItem Header="🏢 Dashboard" Visibility="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToVisibility}}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Stats Row -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DashboardStats.TotalUsers}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#0F172A"/>
                                <TextBlock Text="TOTAL USERS" FontSize="9" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DashboardStats.ActiveUsers}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#059669"/>
                                <TextBlock Text="🟢 ACTIVE" FontSize="9" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DashboardStats.IdleUsers}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#D97706"/>
                                <TextBlock Text="🟡 IDLE" FontSize="9" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource Card}" Padding="14" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DashboardStats.OfflineUsers}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#94A3B8"/>
                                <TextBlock Text="⚫ OFFLINE" FontSize="9" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource Card}" Padding="14" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DashboardStats.ActiveProjects}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#2563EB"/>
                                <TextBlock Text="📁 PROJECTS" FontSize="9" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="5" Style="{StaticResource Card}" Padding="14">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DashboardStats.TotalRevitInstances}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#7C3AED"/>
                                <TextBlock Text="🔧 REVIT" FontSize="9" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- My Status -->
                    <Border Grid.Row="1" Background="White" CornerRadius="10" BorderThickness="1" Padding="12,8" Margin="0,0,0,12"
                            BorderBrush="#D1FAE5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="My Status: " FontWeight="Bold" VerticalAlignment="Center" Foreground="#0F172A"/>
                            <TextBlock Text="{Binding CurrentActivityIcon}" FontSize="15" VerticalAlignment="Center" Margin="3,0"/>
                            <TextBlock Text="{Binding CurrentActivityState}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="Revit: " VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBlock Text="{Binding LocalRevitCount}" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2563EB" Margin="0,0,16,0"/>
                            <TextBlock Text="Project: " VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBlock Text="{Binding LocalCurrentProject}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#2563EB" Margin="0,0,16,0"/>
                            <TextBlock Text="Session: " VerticalAlignment="Center" Foreground="#64748B"/>
                            <TextBlock Text="{Binding LocalSessionDuration}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" Foreground="#059669" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding CurrentIdleText}" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Live Users + Active Projects -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <!-- Live Users -->
                        <Border Grid.Column="0" Style="{StaticResource TableCard}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#EEF1F8" CornerRadius="12,12,0,0" Padding="12,8">
                                    <TextBlock Text="👥 Live Users" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding LiveUsers}" AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" MinRowHeight="36" ColumnHeaderHeight="36" BorderThickness="0">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True"><Setter Property="Background" Value="#F0FDF4"/></DataTrigger>
                                                <DataTrigger Binding="{Binding IsIdle}" Value="True"><Setter Property="Background" Value="#FFFBEB"/></DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F8FAFF"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="SL" Width="30" IsReadOnly="True">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource RowNumberConverter}}"
                                                               HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#94A3B8" FontSize="10"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Sts" Binding="{Binding ActivityStatusIcon}" Width="35">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="14"/><Setter Property="HorizontalAlignment" Value="Center"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActivityStatus}" Value="Active"><Setter Property="Foreground" Value="#059669"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding ActivityStatus}" Value="Idle"><Setter Property="Foreground" Value="#D97706"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding ActivityStatus}" Value="Offline"><Setter Property="Foreground" Value="#94A3B8"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#0F172A"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Rev" Binding="{Binding RevitInstanceCount}" Width="35">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#2563EB"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Projects" Binding="{Binding ProjectsDisplay}" Width="*" MinWidth="180">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="FontSize" Value="11"/><Setter Property="Foreground" Value="#64748B"/><Setter Property="ToolTip" Value="{Binding ProjectsDisplay}"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Version" Binding="{Binding RevitVersion}" Width="75">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#94A3B8"/><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Machine" Binding="{Binding MachineId}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="FontFamily" Value="Consolas"/><Setter Property="FontSize" Value="10"/><Setter Property="Foreground" Value="#94A3B8"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Last" Binding="{Binding LastActivity, StringFormat=HH:mm:ss}" Width="70">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontFamily" Value="Consolas"/><Setter Property="Foreground" Value="#64748B"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Active Projects -->
                        <Border Grid.Column="1" Style="{StaticResource TableCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#EEF1F8" CornerRadius="12,12,0,0" Padding="12,8">
                                    <TextBlock Text="📁 Active Projects" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                                </Border>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding LiveProjects}" SelectedItem="{Binding SelectedLiveProject}"
                                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                          MinRowHeight="34" ColumnHeaderHeight="30" SelectionMode="Single" BorderThickness="0">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F8FAFF"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#EBF0FF"/></Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="#" Width="25" IsReadOnly="True">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource RowNumberConverter}}"
                                                               HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#94A3B8" FontSize="10"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Project" Binding="{Binding ProjectName}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#2563EB"/><Setter Property="ToolTip" Value="{Binding ProjectName}"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="👥" Binding="{Binding ActiveUserCount}" Width="35">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="#059669"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Working On" Binding="{Binding ActiveUsers}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Foreground" Value="#94A3B8"/><Setter Property="ToolTip" Value="{Binding ActiveUsers}"/></Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Project Details -->
                                <Border Grid.Row="2" Background="#EBF0FF" CornerRadius="8" Padding="10" Margin="8,8,8,0"
                                        Visibility="{Binding SelectedLiveProject, Converter={StaticResource NullToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="📋 Details" FontWeight="Bold" Foreground="#2563EB" Margin="0,0,0,6" FontSize="11"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Project:" FontWeight="SemiBold" Foreground="#64748B" Margin="0,1" FontSize="11"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedLiveProject.ProjectName}" TextWrapping="Wrap" Foreground="#2563EB" FontWeight="Bold" Margin="8,1" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Users:" FontWeight="SemiBold" Foreground="#64748B" Margin="0,1" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedLiveProject.ActiveUsers}" TextWrapping="Wrap" Margin="8,1" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Revit:" FontWeight="SemiBold" Foreground="#64748B" Margin="0,1" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedLiveProject.RevitVersion}" Foreground="#94A3B8" Margin="8,1" FontSize="11"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Active:" FontWeight="SemiBold" Foreground="#64748B" Margin="0,1" FontSize="11"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="8,1" FontSize="11">
                                                <Run Text="{Binding SelectedLiveProject.ActiveUserCount, Mode=OneWay}"/>
                                                <Run Text=" user(s) working"/>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Time -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="10,8,10,8">
                                    <TextBlock Text="🕐 " VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DashboardStats.CurrentTime}" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center" Foreground="#0F172A"/>
                                    <TextBlock Text=" | " Foreground="#CBD5E1" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LastSyncTime}" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 7: GENERAL (Admin) -->
            <TabItem Header="⚙️ Settings" Visibility="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer Margin="10" VerticalScrollBarVisibility="Auto">
                    <StackPanel Width="480" HorizontalAlignment="Left">
                        <TextBlock Text="Network Logging" FontSize="14" FontWeight="Bold" Foreground="#2563EB" Margin="0,0,0,12"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Content="Enable network logging" IsChecked="{Binding NetworkLoggingEnabled}" FontSize="12.5" Margin="0,0,0,10"/>
                                <TextBlock Text="LOG FILE PATH" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="#64748B" FontSize="10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NetworkLogPath}" IsReadOnly="True" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="📂 Browse" Command="{Binding BrowseLogPathCommand}" Style="{StaticResource PrimaryButton}" Width="85"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Cloud (Global)" FontSize="14" FontWeight="Bold" Foreground="#2563EB" Margin="0,0,0,12"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <CheckBox Content="Enable cloud logging (international teams)" IsChecked="{Binding CloudLoggingEnabled}" FontSize="12.5" Margin="0,0,0,4"/>
                                <TextBlock Text="Use cloud logging for teams across countries." Foreground="#94A3B8" FontSize="10.5" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <TextBlock Text="CLOUD API URL" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="#64748B" FontSize="10"/>
                                <TextBox Text="{Binding CloudApiUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Text="Example: https://your-server.azurewebsites.net" Foreground="#CBD5E1" FontSize="10" Margin="0,0,0,12"/>
                                <TextBlock Text="API KEY" Margin="0,0,0,4" FontWeight="SemiBold" Foreground="#64748B" FontSize="10"/>
                                <PasswordBox x:Name="ApiKeyBox" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🔗 Test Connection" Command="{Binding TestConnectionCommand}" Style="{StaticResource PrimaryButton}" Width="135" Margin="0,0,8,0"/>
                                    <Button Content="🌐 Dashboard" Command="{Binding OpenDashboardCommand}" Style="{StaticResource SecondaryButton}" Width="110"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Application" FontSize="14" FontWeight="Bold" Foreground="#2563EB" Margin="0,0,0,12"/>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Check Interval (seconds):" VerticalAlignment="Center" Foreground="#334155"/>
                                    <TextBox Grid.Column="1" Text="{Binding CheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <CheckBox Content="Start minimized" IsChecked="{Binding StartMinimized}" Margin="0,0,0,8"/>
                                <CheckBox Content="Start with Windows" IsChecked="{Binding AutoStartEnabled}" Margin="0,0,0,12"/>
                                <Button Content="💾 Save Settings" Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryButton}" Width="120" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Admin" FontSize="14" FontWeight="Bold" Foreground="#2563EB" Margin="0,0,0,12"/>
                        <Border Style="{StaticResource Card}">
                            <Button Content="🔑 Change Password" Command="{Binding ChangePasswordCommand}" Style="{StaticResource PrimaryButton}" Width="160" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 8: DEBUG (Admin) -->
            <TabItem Header="🔧 Debug" Visibility="{Binding IsAdminLoggedIn, Converter={StaticResource BoolToVisibility}}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" Text="{Binding DebugLog}" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11.5"
                             Background="#0F172A" Foreground="#34D399" Padding="12"
                             BorderBrush="#E8EBF2" BorderThickness="1"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="🗑️ Clear Log" Command="{Binding ClearDebugCommand}" Style="{StaticResource SecondaryButton}" Width="100"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E8EBF2" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding LoginStatusText}" VerticalAlignment="Center" FontSize="10.5"
                           Foreground="{Binding IsAutodeskLoggedInDisplay, Converter={StaticResource BoolToColor}, ConverterParameter=#059669|#94A3B8}"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusBarText}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10.5" Foreground="#94A3B8"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0">
                    <TextBlock Text="Current: " VerticalAlignment="Center" FontSize="10.5" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding LocalUserDisplayName}" VerticalAlignment="Center" FontSize="10.5" FontWeight="SemiBold" Foreground="#2563EB"/>
                </StackPanel>
                <TextBlock Grid.Column="3" Text="{Binding AppVersionDisplay}" VerticalAlignment="Center" FontSize="10" Foreground="#CBD5E1"/>
            </Grid>
        </Border>
    </Grid>
</Window>
