<Window x:Class="AutodeskIDMonitor.Views.UpdateNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available" 
        Height="350" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#FAFAFA"
        Topmost="True">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🔄" FontSize="36" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Update Available!" FontSize="20" FontWeight="SemiBold" Foreground="#1976D2"/>
                <TextBlock x:Name="VersionText" Text="A new version of Tangent ID Monitor is ready" FontSize="12" Foreground="#666"/>
            </StackPanel>
        </StackPanel>

        <!-- Version Info -->
        <Border Grid.Row="1" Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Current Version" FontSize="11" Foreground="#666" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CurrentVersionText" Text="v1.5.0" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="➜" FontSize="28" Foreground="#1976D2" VerticalAlignment="Center" Margin="25,0"/>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="New Version" FontSize="11" Foreground="#666" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="NewVersionText" Text="v1.8.1" FontSize="18" FontWeight="Bold" Foreground="#1976D2" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Release Notes -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="What's New:" FontWeight="SemiBold" FontSize="12" Margin="10,8,10,5" Foreground="#333"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,0,10,10">
                    <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" FontSize="12" Foreground="#555">
• System tray support - app minimizes to tray instead of closing
• Correct username detection when running as administrator  
• Start minimized option for Windows startup
• Pause monitoring during system lock
• Auto-update feature
• Bug fixes and performance improvements
                    </TextBlock>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Progress Bar (hidden by default) -->
        <StackPanel x:Name="ProgressPanel" Grid.Row="3" Visibility="Collapsed" Margin="0,0,0,15">
            <TextBlock x:Name="ProgressText" Text="Downloading update..." FontSize="12" Foreground="#666" Margin="0,0,0,8"/>
            <ProgressBar x:Name="ProgressBar" Height="10" Value="0" Maximum="100" Foreground="#1976D2"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="FileSizeText" Grid.Column="0" Text="Download size: ~15 MB" 
                       FontSize="11" Foreground="#999" VerticalAlignment="Center"/>

            <Button x:Name="RemindLaterButton" Grid.Column="1" Content="Remind Me Later" 
                    Width="120" Height="35" Margin="0,0,10,0"
                    Click="RemindLater_Click"
                    Background="White" BorderBrush="#BDBDBD" Cursor="Hand"/>

            <Button x:Name="UpdateNowButton" Grid.Column="2" Content="⬇ Update Now" 
                    Width="130" Height="35"
                    Click="UpdateNow_Click"
                    Background="#1976D2" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
