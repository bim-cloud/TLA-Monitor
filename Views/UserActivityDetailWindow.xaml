<Window x:Class="AutodeskIDMonitor.Views.UserActivityDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AutodeskIDMonitor.Converters"
        Title="User Activity Details" Height="550" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F5F7FA">
    
    <Window.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        
        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#000"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Activity Badge Style -->
        <Style x:Key="ActivityBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Padding="20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00B4D8" Offset="0"/>
                    <GradientStop Color="#0096C7" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- User Avatar -->
                <Border Grid.Column="0" Width="56" Height="56" CornerRadius="28" Background="White" Margin="0,0,16,0">
                    <TextBlock x:Name="UserInitials" Text="AJ" FontSize="24" FontWeight="Bold" 
                               Foreground="#00B4D8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="UserNameText" Text="User Name" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="DateText" Text="Today's Activity" FontSize="14" Foreground="#E0F7FA" Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Status Badge -->
                <Border x:Name="StatusBadge" Grid.Column="2" CornerRadius="16" Padding="12,6" Background="#4CAF50" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="🟢 Active" FontWeight="SemiBold" Foreground="White" FontSize="13"/>
                </Border>
            </Grid>
        </Border>
        
        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <!-- Activity Summary Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="📊 Activity Summary" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                        
                        <WrapPanel>
                            <!-- Revit Work -->
                            <Border Style="{StaticResource ActivityBadge}" Background="#E3F2FD">
                                <StackPanel>
                                    <TextBlock Text="Active Revit Work" FontSize="11" Foreground="#1976D2"/>
                                    <TextBlock x:Name="RevitHoursText" Text="0.0h" FontSize="24" FontWeight="Bold" Foreground="#1565C0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Meetings -->
                            <Border Style="{StaticResource ActivityBadge}" Background="#F3E5F5">
                                <StackPanel>
                                    <TextBlock Text="Meetings" FontSize="11" Foreground="#7B1FA2"/>
                                    <TextBlock x:Name="MeetingHoursText" Text="0.0h" FontSize="24" FontWeight="Bold" Foreground="#6A1B9A"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Idle -->
                            <Border Style="{StaticResource ActivityBadge}" Background="#FFF8E1">
                                <StackPanel>
                                    <TextBlock Text="Idle" FontSize="11" Foreground="#F57C00"/>
                                    <TextBlock x:Name="IdleHoursText" Text="0.0h" FontSize="24" FontWeight="Bold" Foreground="#EF6C00"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Total -->
                            <Border Style="{StaticResource ActivityBadge}" Background="#E8F5E9">
                                <StackPanel>
                                    <TextBlock Text="Total Work" FontSize="11" Foreground="#388E3C"/>
                                    <TextBlock x:Name="TotalHoursText" Text="0.0h" FontSize="24" FontWeight="Bold" Foreground="#2E7D32"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                
                <!-- Project Breakdown Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="📁 Project Breakdown" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                        
                        <ItemsControl x:Name="ProjectList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" Foreground="#333" 
                                                           TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="1" Text="{Binding ActiveTimeDisplay}" 
                                                       FontWeight="Bold" Foreground="#1976D2" FontSize="14" Margin="12,0"/>
                                            
                                            <Border Grid.Column="2" CornerRadius="10" Padding="8,3"
                                                    Background="{Binding StatusBackground}">
                                                <TextBlock Text="{Binding StatusDisplay}" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <TextBlock x:Name="NoProjectsText" Text="No projects tracked yet" 
                                   Foreground="#999" FontStyle="Italic" Visibility="Collapsed" Margin="0,8"/>
                    </StackPanel>
                </Border>
                
                <!-- Hourly Breakdown Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="🕐 Hourly Breakdown" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                        <ItemsControl x:Name="HourlyList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,4" Margin="0,0,6,6" Background="{Binding BackgroundColor}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding HourLabel}" FontSize="11" Foreground="#666" Width="35"/>
                                            <TextBlock Text="{Binding TotalDisplay}" FontWeight="SemiBold" Foreground="{Binding TextColor}" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="White" Padding="20,12" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="LastUpdatedText" Text="Last updated: just now" VerticalAlignment="Center" 
                           Foreground="#666" FontSize="12"/>
                
                <Button x:Name="ExportButton" Grid.Column="1" Content="📥 Export Activity" 
                        Padding="16,8" Margin="0,0,10,0" Cursor="Hand"
                        Background="#00B4D8" Foreground="White" FontWeight="SemiBold"
                        BorderThickness="0" Click="ExportButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#0096C7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button x:Name="CloseButton" Grid.Column="2" Content="Close" 
                        Padding="16,8" Cursor="Hand"
                        Background="#F5F5F5" Foreground="#333" FontWeight="SemiBold"
                        BorderThickness="0" Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#EEEEEE"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
    
    <!-- Window Load Animation -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
