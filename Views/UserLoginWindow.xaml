<Window x:Class="AutodeskIDMonitor.Views.UserLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tangent ID Monitor – Sign In"
        Height="520" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border CornerRadius="12" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.25"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="28,22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A3A5C" Offset="0"/>
                        <GradientStop Color="#2596BE" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="Tangent ID Monitor" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Sign in to continue" FontSize="13" Foreground="#B0D8F0" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="32,20">

                <!-- Name (first-time only) -->
                <StackPanel x:Name="NamePanel" Visibility="Collapsed">
                    <TextBlock Text="Full Name" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
                    <Border BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="6">
                        <TextBox x:Name="NameBox" FontSize="13" Padding="10,9" BorderThickness="0"
                                 VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Email -->
                <TextBlock Text="Work Email" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,14,0,5"/>
                <Border BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="6">
                    <TextBox x:Name="EmailBox" FontSize="13" Padding="10,9" BorderThickness="0"
                             VerticalContentAlignment="Center"
                             TextChanged="EmailBox_TextChanged"/>
                </Border>
                <TextBlock Text="e.g. anshu.jalaludeen@tangentlandscape.com" FontSize="10"
                           Foreground="#999" Margin="2,3,0,0"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,16,0,5"/>
                <Border BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="6">
                    <PasswordBox x:Name="PasswordBox" FontSize="13" Padding="10,9" BorderThickness="0"
                                 KeyDown="PasswordBox_KeyDown"/>
                </Border>

                <!-- Forgot password -->
                <TextBlock HorizontalAlignment="Right" Margin="0,8,2,0">
                    <Hyperlink x:Name="ForgotLink" Click="ForgotPassword_Click"
                               Foreground="#2596BE" FontSize="12">Forgot password?</Hyperlink>
                </TextBlock>

                <!-- Reset result message -->
                <TextBlock x:Name="ResetMessage" Foreground="#2E7D32" FontSize="11"
                           Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                <!-- Error -->
                <TextBlock x:Name="ErrorText" Foreground="#C62828" FontSize="12"
                           Margin="0,10,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                <!-- Sign In button -->
                <Button x:Name="SignInBtn" Content="Sign In" Height="42" Margin="0,20,0,0"
                        FontSize="14" FontWeight="Bold"
                        Background="#2596BE" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="SignIn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="7">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
            
            <!-- Footer -->
            <Border Grid.Row="2" Background="#F7F9FC" CornerRadius="0,0,12,12" Padding="32,14">
                <TextBlock Text="© 2026 Tangent Landscape Architecture  •  Dubai, UAE (UTC+4)"
                           FontSize="10" Foreground="#AAA" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
